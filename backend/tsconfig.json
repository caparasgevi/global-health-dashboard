{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",           
    "moduleResolution": "Node16", 
    "lib": ["ES2022"],
    "rootDir": "./",
    "outDir": "./dist",
    "types": ["node"],
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}