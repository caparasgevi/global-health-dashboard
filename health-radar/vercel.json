{
  "rewrites": [
    {
      "source": "/gho-api/:path*",
      "destination": "https://ghoapi.azureedge.net/api/:path*"
    },
    {
      "source": "/who-news/:path*",
      "destination": "https://www.who.int/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}