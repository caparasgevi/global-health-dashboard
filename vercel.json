{
  "version": 2,
  "functions": {
    "backend/index.js": {
      "runtime": "nodejs20.x"
    }
  },
  "builds": [
    {
      "src": "backend/index.ts",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/health-radar/$1"
    }
  ]
}