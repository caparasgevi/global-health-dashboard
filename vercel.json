{
  "version": 2,
  "builds": [
    {
      "src": "backend/src/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "health-radar/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/backend/src/index.ts" },
    { "src": "^/assets/(.*)$", "dest": "/assets/$1" },
    { "src": "^/(.+\\.[a-z]+)$", "dest": "/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}