{
  "version": 2,
  "functions": {
    "backend/src/index.ts": {
      "runtime": "@vercel/node"
    }
  },
  "builds": [
    {
      "src": "health-radar/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "health-radar/dist" }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/backend/src/index.ts" },
    { "source": "/(.*)", "destination": "/health-radar/dist/$1" }
  ]
}